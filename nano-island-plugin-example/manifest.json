{
  "id": "nano-island-plugin-example",
  "name": "示例时钟插件",
  "version": "1.0.0",
  "description": "一个完整的示例插件，展示所有组件类型和 TailwindCSS 支持",
  "author": "Nano Island Team",
  "icon": "🕐",
  "screenshots": [
    "screenshots/插件商店.png"
  ],
  "isReleased": true,
  "isOfficial": true,
  "permissions": [
    "storage:read",
    "storage:write"
  ],
  "entry": {
    "main": "main"
  },
  "interfaces": {
    "regular": {
      "entry": "regular",
      "defaultProps": {
        "theme": "dark"
      }
    },
    "expanded": {
      "entry": "expanded",
      "width": 400,
      "height": 500
    },
    "resident": {
      "entry": "resident",
      "colspan": 2,
      "rowspan": 1
    },
    "settings": {
      "entry": "settings",
      "title": "时钟设置"
    },
    "menu": [
      {
        "id": "settings",
        "label": "插件设置",
        "icon": "⚙️",
        "entry": "settings"
      },
      {
        "id": "api-demo",
        "label": "API 示例",
        "icon": "🔌",
        "entry": "api-demo"
      }
    ]
  }
}